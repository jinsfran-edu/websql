PORT=3000
READ_ONLY_MODE=true
QUERY_TIMEOUT_MS=15000
# Tamaño máximo del pool de conexiones por motor (default 10). El pool vive por
# proceso: corré la app en UN SOLO instance, o dividí estos valores por la
# cantidad de instancias. Ojo con el tope de conexiones del tier de cada base
# (p. ej. PostgreSQL Burstable B1ms ~35). Para ~55 alumnos: SQLSERVER 20, MYSQL 15, POSTGRES 12.
# SQLSERVER_POOL_MAX=20
# SQLSERVER_POOL_MIN=1
# MYSQL_POOL_MAX=15
# POSTGRES_POOL_MAX=12
# Optional hardening: comma-separated origins, e.g. https://myapp.azurewebsites.net
# CORS_ALLOWED_ORIGINS=
# Panel docente (admin.html / /api/stats): si se define, exige ?key=ADMIN_KEY.
# Recomendado en producción porque el panel muestra IPs y consultas.
# ADMIN_KEY=

# SQL Server
SQLSERVER_HOST=servidorsql
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=basededatos
SQLSERVER_USER=usuario
SQLSERVER_PASSWORD=contraseña

# Segunda base en el mismo SQL Server (opcional)
SQLSERVER_LIBRARY_DATABASE=library
SQLSERVER_LIBRARY_USER=usuario2
SQLSERVER_LIBRARY_PASSWORD=contraseña2

# MySQL
MYSQL_HOST=servidormysql
MYSQL_PORT=3306
MYSQL_DATABASE=basededatos
MYSQL_USER=usuario
MYSQL_PASSWORD=contraseña
MYSQL_SSL=true

# PostgreSQL
POSTGRES_HOST=servidorpostgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=basededatos
POSTGRES_USER=usuario
POSTGRES_PASSWORD=contraseña
POSTGRES_SSL=true
