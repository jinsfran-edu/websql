PORT=3000
READ_ONLY_MODE=true
# Optional hardening: comma-separated origins, e.g. https://myapp.azurewebsites.net
# CORS_ALLOWED_ORIGINS=

# SQL Server
SQLSERVER_HOST=servidorsql
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=basededatos
SQLSERVER_USER=usuario
SQLSERVER_PASSWORD=contraseña

# MySQL
MYSQL_HOST=servidormysql
MYSQL_PORT=3306
MYSQL_DATABASE=basededatos
MYSQL_USER=usuario
MYSQL_PASSWORD=contraseña
MYSQL_SSL=true

# PostgreSQL
POSTGRES_HOST=servidorpostgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=basededatos
POSTGRES_USER=usuario
POSTGRES_PASSWORD=contraseña
POSTGRES_SSL=true
